#80FF00<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Addis Power · AI & Web Solution</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: #0a0a14;
            color: #fff;
            overflow-x: hidden;
        }

        /* Animated Background */
        .bg-gradient {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background: 
                radial-gradient(circle at 20% 30%, rgba(139, 92, 246, 0.3) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(245, 158, 11, 0.25) 0%, transparent 40%),
                radial-gradient(circle at 50% 50%, rgba(6, 182, 212, 0.15) 0%, transparent 50%);
            animation: bgPulse 15s ease-in-out infinite alternate;
        }

        @keyframes bgPulse {
            0% { opacity: 0.7; filter: hue-rotate(0deg); }
            100% { opacity: 1; filter: hue-rotate(15deg); }
        }

        /* Floating Particles */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: rgba(245, 158, 11, 0.6);
            border-radius: 50%;
            animation: floatParticle 20s infinite linear;
            box-shadow: 0 0 15px #f59e0b;
        }

        @keyframes floatParticle {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
        }

        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 24px;
            position: relative;
            z-index: 10;
        }

        /* Header */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            flex-wrap: wrap;
            gap: 20px;
        }

        /* ===== 3D CUBE LOGO WITH CODE SIGNS ===== */
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .cube-wrapper {
            width: 55px;
            height: 55px;
            animation: cubeFloat 4s ease-in-out infinite;
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        @keyframes cubeFloat {
            0%, 100% { transform: translateY(0) rotateY(0deg) rotateX(0deg); }
            25% { transform: translateY(-6px) rotateY(-8deg) rotateX(5deg); }
            50% { transform: translateY(0) rotateY(0deg) rotateX(10deg); }
            75% { transform: translateY(4px) rotateY(8deg) rotateX(-5deg); }
        }

        .cube-3d {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            animation: spinCube 12s infinite linear;
        }

        @keyframes spinCube {
            0% { transform: rotateX(-20deg) rotateY(0deg); }
            100% { transform: rotateX(-20deg) rotateY(360deg); }
        }

        .cube-face {
            position: absolute;
            width: 55px;
            height: 55px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.9), rgba(6, 182, 212, 0.9));
            border: 2px solid rgba(245, 158, 11, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            text-shadow: 0 0 10px rgba(255,255,255,0.5);
            box-shadow: 0 0 20px rgba(139, 92, 246, 0.5);
            backdrop-filter: blur(5px);
        }

        .cube-face i {
            font-size: 26px;
            color: #fff;
            filter: drop-shadow(0 0 8px #f59e0b);
        }

        .front { transform: translateZ(27.5px); background: linear-gradient(135deg, #8b5cf6, #06b6d4); }
        .back { transform: rotateY(180deg) translateZ(27.5px); background: linear-gradient(135deg, #f59e0b, #8b5cf6); }
        .right { transform: rotateY(90deg) translateZ(27.5px); background: linear-gradient(135deg, #06b6d4, #ec4899); }
        .left { transform: rotateY(-90deg) translateZ(27.5px); background: linear-gradient(135deg, #ec4899, #f59e0b); }
        .top { transform: rotateX(90deg) translateZ(27.5px); background: linear-gradient(135deg, #8b5cf6, #ec4899); }
        .bottom { transform: rotateX(-90deg) translateZ(27.5px); background: linear-gradient(135deg, #06b6d4, #f59e0b); }

        .logo-text-group {
            display: flex;
            flex-direction: column;
        }

        .logo-main {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.5px;
            line-height: 1.1;
        }

        .logo-main .addis {
            background: linear-gradient(135deg, #fff, #e0e7ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .logo-main .power {
            background: linear-gradient(135deg, #f59e0b, #8b5cf6, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .logo-sub {
            font-size: 11px;
            color: #a1a1aa;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            font-weight: 400;
        }

        nav {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .nav-link {
            color: #a1a1aa;
            text-decoration: none;
            padding: 10px 18px;
            border-radius: 30px;
            font-weight: 500;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .nav-link i {
            color: #f59e0b;
        }

        .nav-link:hover {
            color: #fff;
            background: rgba(245, 158, 11, 0.15);
            border-color: rgba(245, 158, 11, 0.3);
            transform: translateY(-2px);
        }

        .nav-link.highlight {
            background: linear-gradient(135deg, #8b5cf6, #f59e0b);
            color: #fff;
            border: none;
        }

        /* Hero Section */
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
            padding: 50px 0;
            min-height: calc(100vh - 120px);
        }

        .hero-content {
            animation: fadeInUp 0.8s ease-out;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(245, 158, 11, 0.15);
            border: 1px solid rgba(245, 158, 11, 0.3);
            padding: 8px 20px;
            border-radius: 40px;
            font-size: 14px;
            margin-bottom: 24px;
        }

        .badge i {
            color: #f59e0b;
        }

        .hero h1 {
            font-size: clamp(40px, 6vw, 64px);
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 24px;
        }

        .gradient-text {
            background: linear-gradient(135deg, #f59e0b, #8b5cf6, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 18px;
            color: #a1a1aa;
            margin-bottom: 36px;
            max-width: 500px;
            line-height: 1.7;
        }

        .stats {
            display: flex;
            gap: 40px;
            margin-bottom: 36px;
        }

        .stat-item h3 {
            font-size: 32px;
            font-weight: 700;
            color: #f59e0b;
        }

        .stat-item p {
            font-size: 14px;
            margin-bottom: 0;
            color: #71717a;
        }

        .btn-group {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
            font-size: 16px;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: linear-gradient(135deg, #f59e0b, #8b5cf6);
            color: #fff;
            box-shadow: 0 10px 30px rgba(245, 158, 11, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 40px rgba(245, 158, 11, 0.4);
        }

        .btn-outline {
            background: transparent;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .btn-outline:hover {
            border-color: #f59e0b;
            background: rgba(245, 158, 11, 0.1);
            transform: translateY(-3px);
        }

        .hero-visual {
            position: relative;
            animation: fadeInRight 0.8s ease-out;
        }

        @keyframes fadeInRight {
            from { opacity: 0; transform: translateX(30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .vector-card {
            background: rgba(20, 20, 40, 0.6);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 30px;
            border: 1px solid rgba(245, 158, 11, 0.2);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }

        /* Section Titles */
        .section-title {
            text-align: center;
            margin-bottom: 50px;
        }

        .section-title h2 {
            font-size: clamp(32px, 5vw, 48px);
            font-weight: 700;
            margin-bottom: 12px;
        }

        .section-title p {
            color: #a1a1aa;
            font-size: 18px;
        }

        /* Services */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            padding: 30px 0;
        }

        .service-card {
            background: rgba(20, 20, 40, 0.5);
            backdrop-filter: blur(15px);
            border-radius: 24px;
            padding: 30px 24px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s;
            text-align: center;
        }

        .service-card:hover {
            transform: translateY(-8px);
            border-color: rgba(245, 158, 11, 0.3);
        }

        .service-icon {
            width: 65px;
            height: 65px;
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(139, 92, 246, 0.2));
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .service-icon i {
            font-size: 30px;
            color: #f59e0b;
        }

        .service-card h3 {
            font-size: 20px;
            margin-bottom: 10px;
        }

        .service-card p {
            color: #a1a1aa;
            font-size: 14px;
            line-height: 1.6;
        }

        /* ===== PORTFOLIO GALLERY ===== */
        .portfolio-section {
            padding: 60px 0;
        }

        .portfolio-filter {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .filter-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #a1a1aa;
            padding: 10px 24px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
        }

        .filter-btn:hover, .filter-btn.active {
            background: linear-gradient(135deg, #f59e0b, #8b5cf6);
            color: #fff;
            border-color: transparent;
        }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
        }

        .portfolio-item {
            background: rgba(20, 20, 40, 0.6);
            backdrop-filter: blur(15px);
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s;
            cursor: pointer;
        }

        .portfolio-item:hover {
            transform: translateY(-10px);
            border-color: rgba(245, 158, 11, 0.4);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }

        .portfolio-image {
            height: 200px;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .portfolio-image i {
            font-size: 60px;
            color: #f59e0b;
            opacity: 0.8;
        }

        .portfolio-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.8), rgba(6, 182, 212, 0.8));
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            opacity: 0;
            transition: all 0.3s;
        }

        .portfolio-item:hover .portfolio-overlay {
            opacity: 1;
        }

        .portfolio-overlay a {
            width: 45px;
            height: 45px;
            background: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #1a1a2e;
            font-size: 18px;
            transition: all 0.3s;
        }

        .portfolio-overlay a:hover {
            background: #f59e0b;
            color: #fff;
            transform: scale(1.1);
        }

        .portfolio-info {
            padding: 20px;
        }

        .portfolio-category {
            font-size: 12px;
            color: #f59e0b;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .portfolio-info h3 {
            font-size: 20px;
            margin-bottom: 8px;
        }

        .portfolio-info p {
            color: #a1a1aa;
            font-size: 14px;
        }

        /* ===== TESTIMONIALS CAROUSEL ===== */
        .testimonials-section {
            padding: 60px 0;
        }

        .testimonials-carousel {
            position: relative;
            max-width: 900px;
            margin: 0 auto;
            overflow: hidden;
        }

        .testimonials-track {
            display: flex;
            transition: transform 0.5s ease;
        }

        .testimonial-card {
            min-width: 100%;
            padding: 20px;
        }

        .testimonial-content {
            background: rgba(20, 20, 40, 0.7);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 40px;
            border: 1px solid rgba(245, 158, 11, 0.2);
            text-align: center;
        }

        .testimonial-quote {
            font-size: 60px;
            color: #f59e0b;
            opacity: 0.3;
            margin-bottom: -20px;
        }

        .testimonial-text {
            font-size: 18px;
            line-height: 1.7;
            color: #e0e7ff;
            margin-bottom: 25px;
        }

        .testimonial-rating {
            margin-bottom: 25px;
        }

        .testimonial-rating i {
            color: #f59e0b;
            font-size: 18px;
            margin: 0 2px;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        .author-avatar {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #f59e0b, #8b5cf6);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 600;
            color: #fff;
        }

        .author-info h4 {
            font-size: 18px;
            margin-bottom: 4px;
        }

        .author-info p {
            color: #a1a1aa;
            font-size: 14px;
        }

        .company-badge {
            display: inline-block;
            background: rgba(245, 158, 11, 0.15);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            color: #f59e0b;
            margin-top: 8px;
        }

        .carousel-nav {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 30px;
        }

        .carousel-btn {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 20px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .carousel-btn:hover {
            background: linear-gradient(135deg, #f59e0b, #8b5cf6);
            border-color: transparent;
        }

        .carousel-dots {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 20px;
        }

        .dot {
            width: 10px;
            height: 10px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            cursor: pointer;
            transition: all 0.3s;
        }

        .dot.active {
            background: #f59e0b;
            width: 25px;
            border-radius: 10px;
        }

        /* Pricing */
        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            padding: 40px 0;
        }

        .pricing-card {
            background: rgba(20, 20, 40, 0.5);
            backdrop-filter: blur(15px);
            border-radius: 28px;
            padding: 40px 30px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .pricing-card.featured {
            border-color: rgba(245, 158, 11, 0.4);
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(139, 92, 246, 0.1));
        }

        .pricing-card.featured::before {
            content: 'Most Popular';
            position: absolute;
            top: 20px;
            right: -35px;
            background: linear-gradient(135deg, #f59e0b, #8b5cf6);
            color: #fff;
            padding: 5px 40px;
            font-size: 12px;
            font-weight: 600;
            transform: rotate(45deg);
        }

        .pricing-card:hover {
            transform: translateY(-8px);
        }

        .price-name {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .price-amount {
            font-size: 48px;
            font-weight: 700;
            color: #f59e0b;
        }

        .price-period {
            color: #71717a;
            font-size: 16px;
        }

        .price-features {
            list-style: none;
            margin: 30px 0;
        }

        .price-features li {
            padding: 10px 0;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #a1a1aa;
        }

        .price-features i {
            color: #f59e0b;
            font-size: 18px;
        }

        .flexible-badge {
            display: inline-block;
            background: rgba(245, 158, 11, 0.15);
            border: 1px solid rgba(245, 158, 11, 0.3);
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 13px;
            color: #fbbf24;
        }

        /* Chatbot */
        .chatbot-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 1000;
        }

        .chatbot-toggle {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #f59e0b, #8b5cf6);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 10px 40px rgba(245, 158, 11, 0.4);
            transition: all 0.3s;
            animation: pulseGlow 2s infinite;
        }

        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 10px 40px rgba(245, 158, 11, 0.4); }
            50% { box-shadow: 0 15px 50px rgba(139, 92, 246, 0.6); }
        }

        .chatbot-toggle i {
            font-size: 28px;
            color: #fff;
        }

        .chatbot-window {
            position: absolute;
            bottom: 80px;
            right: 0;
            width: 350px;
            height: 500px;
            background: rgba(20, 20, 40, 0.95);
            backdrop-filter: blur(25px);
            border-radius: 24px;
            border: 1px solid rgba(245, 158, 11, 0.3);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            display: none;
            flex-direction: column;
            overflow: hidden;
        }

        .chatbot-window.active {
            display: flex;
        }

        .chatbot-header {
            background: linear-gradient(135deg, #f59e0b, #8b5cf6);
            padding: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .chatbot-avatar {
            width: 40px;
            height: 40px;
            background: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .chatbot-avatar i {
            font-size: 22px;
            color: #f59e0b;
        }

        .chatbot-header h3 {
            font-size: 16px;
        }

        .chatbot-header p {
            font-size: 11px;
            opacity: 0.8;
        }

        .chatbot-close {
            margin-left: auto;
            cursor: pointer;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
        }

        .chatbot-messages {
            flex: 1;
            padding: 18px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .message {
            display: flex;
            gap: 8px;
        }

        .message.bot {
            align-items: flex-start;
        }

        .message.user {
            flex-direction: row-reverse;
        }

        .message-avatar {
            width: 30px;
            height: 30px;
